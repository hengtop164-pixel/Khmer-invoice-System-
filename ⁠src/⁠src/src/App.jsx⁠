      </button>
      <div className="mt-2 pt-2 border-t border-slate-100 flex justify-between items-center text-sm font-bold text-slate-300 uppercase tracking-widest">
        <span>Serial #{form.invoiceNo}</span><span>Digital Record</span>
      </div>
