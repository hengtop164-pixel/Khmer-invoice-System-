// Tap-5-times-on-logo trigger for the hidden admin panel
const SecretLogo = ({ size, onSecret }) => {
  const taps = useRef([]);
  const handleTap = () => {
    const now = Date.now();
    taps.current = [...taps.current.filter(t => now - t < 3000), now];
