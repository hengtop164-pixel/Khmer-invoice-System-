          <div className="shrink-0 mt-2"><BrandMark size={44} /></div>
          <div className="space-y-1">
            <h1 className="text-base sm:text-3xl font-black tracking-tighter leading-none">វិក្កយបត្រ <span className="text-[#2F5A96] text-sm font-bold">INVOICE</span></h1>
            <div className="h-[3px] w-10 bg-[#C9A227] rounded-full mt-2 mb-2"></div>
            <p className="text-sm font-black text-[#0A1830] uppercase tracking-tight">{profile.businessName}</p>
            <div className="flex items-center gap-2 text-sm font-semibold text-slate-400 mt-2"><Phone size={10} className="text-slate-300" /> <span>{profile.phone}</span></div>
          </div>
        </div>
        <div className="text-right">
          <p className="text-base font-black font-mono tracking-tighter text-[#2F5A96]">#{String(form.invoiceNo).padStart(6, '0')}</p>
          <p className="text-sm font-semibold text-slate-400 italic">{new Date(form.date).toLocaleDateString()}</p>
        </div>
      </div>

      <div className="mb-2 space-y-1">
        <p className="text-sm font-bold text-slate-300 uppercase tracking-widest">អតិថិជន · Recipient</p>
        <h2 className="text-base font-black tracking-tight uppercase">{form.custName || '---'}</h2>
        {form.custPhone && <p className="text-sm font-bold text-slate-400">{form.custPhone}</p>}
      </div>

      <div className="flex-grow mb-2 overflow-x-auto">
        <table className="w-full min-w-[300px]">
          <thead className="bg-[#F7F9FC] text-sm font-black text-slate-400 uppercase tracking-widest">
            <tr><th className="py-2 px-2 text-left">បរិយាយ · Item</th><th className="py-2 px-2 text-center">ថ្លៃ · Price</th><th className="py-2 px-2 text-center">ចំនួន · Qty</th><th className="py-2 px-2 text-right">សរុប · Total</th></tr>
          </thead>
          <tbody className="divide-y divide-slate-100">
            {form.items.length > 0 ? form.items.map(i => (
              <tr key={i.id}>
                <td className="py-2 px-2 font-bold text-sm uppercase">{i.description}</td>
                <td className="py-2 px-2 text-center text-sm text-slate-400 font-bold">{fmtMoney(i.unitPrice, form.currency)}</td>
                <td className="py-2 px-2 text-center text-sm font-black">{i.quantity} {i.unit}</td>
                <td className="py-2 px-2 text-right font-black text-sm">{fmtMoney(i.total, form.currency)}</td>
              </tr>
            )) : <tr><td colSpan="4" className="py-2 text-center text-sm text-slate-300 font-bold uppercase italic">No items</td></tr>}
          </tbody>
        </table>
      </div>

      <div className="flex flex-col items-end pt-2 border-t border-slate-200">
        <div className="w-full sm:w-60 space-y-1.5">
          <div className="flex justify-between text-sm font-bold text-slate-400 uppercase"><span>សរុបរង · Subtotal</span><span>{fmtMoney(subtotal, form.currency)}</span></div>
          {discountAmt > 0 && <div className="flex justify-between text-sm font-bold text-[#C9A227] uppercase"><span>បញ្ចុះតម្លៃ · Discount</span><span>-{fmtMoney(discountAmt, form.currency)}</span></div>}
          <div className="flex justify-between text-[#2F5A96] text-sm font-black uppercase"><span>បានបង់ · Paid</span><span>{fmtMoney(totalPaidInForm, form.currency)}</span></div>
          <div className="pt-2 border-t-2 border-[#0A1830] mt-2">
            <div className="flex justify-between items-center"><span className="text-sm font-black uppercase">ត្រូវទូទាត់ · Balance</span><span className="text-base font-black tracking-tighter">{fmtMoney(balanceDue, form.currency)}</span></div>
